<service>
  <id>ScummImageService</id>
  <name>Scumm Image Service</name>
  <description>SCUMM-L image_service (uvicorn) on port 8010</description>
  <executable>C:\Users\aaron\AppData\Local\Programs\Python\Python312\python.exe</executable>
  <arguments>-m uvicorn image_service:app --host 0.0.0.0 --port 8010</arguments>
  <workingdirectory>D:\scumm-l-image-service</workingdirectory>
  <env name="PYTHONPATH" value="D:\scumm-l-image-service"/>
  <logpath>D:\scumm-l-image-service\logs</logpath>
  <logmode>rotate</logmode>
  <rotatetype>size</rotatetype>
  <rotatesize>10485760</rotatesize>
  <stopmode>default</stopmode>
  <stoptimeout>30 sec</stoptimeout>
  <startmode>Automatic</startmode>
  <onfailure action="restart" delay="5 sec"/>
  <onfailure action="restart" delay="10 sec"/>
  <onfailure action="restart" delay="30 sec"/>
</service>
